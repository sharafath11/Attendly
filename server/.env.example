# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/attendly

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Auth secrets (use: openssl rand -base64 32) ─────────────────────────────
JWT_SECRET=replace-with-a-32-plus-char-random-string
REFRESH_SECRET=replace-with-a-different-32-plus-char-random-string

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_USER=your-email@example.com
MAILBLUSTER_API_KEY=your-mailbluster-key

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id

# ─── AI keys ─────────────────────────────────────────────────────────────────
OPEN_ROUTER_KEY=your-openrouter-key
GEMINI_KEY=your-gemini-key

# ─── Admin credentials ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# ─── Redis (required for BullMQ + OTP throttle) ──────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:6379   # alternative — takes priority over REDIS_HOST

# ─── WhatsApp (Baileys self-hosted) ──────────────────────────────────────────
# Directory where Baileys saves auth state (QR / session keys)
WA_AUTH_DIR=./whatsapp-auth
# Set to "info" or "debug" for verbose Baileys logging
WA_LOG_LEVEL=silent

# ─── Frontend / CORS ─────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ─── Cookies ─────────────────────────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=your-domain.com   ← bare domain, NO https:// prefix

# ─── Payments ────────────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ─── Debug ───────────────────────────────────────────────────────────────────
AUTH_DEBUG=false
